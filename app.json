{
  "expo": {
    "name": "Şafak Sayar Pro",
    "slug": "safak-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tabugoapp.safakpro",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserTrackingUsageDescription": "Sana daha alakalı reklamlar gösterebilmek için izin istiyoruz. İzin vermezsen reklamlar görünmeye devam eder ancak kişiselleştirilmez."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tabugoapp.safakpro"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#10b981"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7780845735147349~4471114770",
          "iosAppId": "ca-app-pub-7780845735147349~8723250788"
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Uygulamanın ücretsiz kalabilmesi için size daha uygun reklamlar göstermemize izin verir misiniz?"
        }
      ],
      "react-native-iap"
    ],
    "extra": {
      "eas": {
        "projectId": "c28ab7e6-b8b0-45dd-aea0-4b3f953b4d92"
      }
    },
    "owner": "tabugoapp"
  }
}